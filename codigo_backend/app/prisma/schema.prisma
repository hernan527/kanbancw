generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Funnel {
  id            Int            @id @default(autoincrement())
  name          String
  accountId     Int
  order         Int            @default(0)
  color         String         @default("#3B82F6")
  isPublic      Boolean        @default(false)  // Se true, todos os usuários podem ver
  isSystem      Boolean        @default(false)  // Se true, é o funil de sistema (Status Chatwoot)
  isActive      Boolean        @default(true)   // Se true, o funil está ativo e visível
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  stages        Stage[]
  allowedUsers  FunnelAccess[]
  itemTemplates ItemTemplate[]
  customFields  CustomField[]  // Campos personalizados do funil

  @@index([accountId])
  @@index([accountId, isSystem])  // Para queries otimizadas de funil de sistema
  @@index([accountId, isActive])  // Para queries de funis ativos
}

// Usuários com acesso a um funil específico
model FunnelAccess {
  id        Int      @id @default(autoincrement())
  funnelId  Int
  userId    Int
  createdAt DateTime @default(now())
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, userId])
  @@index([funnelId])
  @@index([userId])
}

model Stage {
  id             Int      @id @default(autoincrement())
  name           String
  funnelId       Int
  order          Int      @default(0)
  color          String   @default("#6B7280")
  chatwootStatus String?  // Para funil de sistema: "open", "pending", "resolved" ou null para colunas extras
  automations    String?  @db.Text // JSON com automações: {"newTicket": true, "inboxIds": [1,2], "labelTriggers": ["venda"]}
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  funnel         Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  cards          Card[]

  @@index([funnelId])
}

model Card {
  id             Int      @id @default(autoincrement())
  conversationId Int?     // Null para cards avulsos (sem ticket associado)
  stageId        Int
  accountId      Int
  order          Int      @default(0)
  customName     String?  // Nome customizado do card (editável pelo usuário)
  ai_score       Int?     // Score gerado por IA (1-100)
  ai_analysis    String?  @db.Text // Análise comercial gerada pela IA
  transferredFrom String? @db.Text  // JSON: {"funnelId": 1, "funnelName": "...", "stageId": 2, "stageName": "...", "transferredAt": "..."}
  leadStatus     String   @default("open")  // Status do lead: "open", "won", "lost"
  closeReason    String?  // Motivo do fechamento (ganho ou perda)
  closedAt       DateTime? // Timestamp de quando foi marcado como won/lost
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  stage          Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  items          CardItem[]
  customFieldValues CustomFieldValue[]

  @@unique([conversationId, accountId])
  @@index([stageId])
  @@index([accountId])
}

// ============================================================================
// CAMPOS PERSONALIZADOS - Custom Fields para Cards
// ============================================================================

// Template de campo personalizado (definição do campo) - POR FUNIL
model CustomField {
  id          Int      @id @default(autoincrement())
  funnelId    Int      // Vinculado ao funil, não mais global
  name        String   // Nome do campo (ex: "CPF", "Data de Nascimento")
  fieldType   String   // Tipo: text, number, date, select, multi_select, checkbox, url, email, phone
  options     String?  @db.Text // JSON com opções para select/multi_select: ["Opção 1", "Opção 2"]
  required    Boolean  @default(false)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  funnel      Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  values      CustomFieldValue[]

  @@index([funnelId])
  @@index([funnelId, isActive])
}

// Valores dos campos personalizados por card
model CustomFieldValue {
  id            Int         @id @default(autoincrement())
  cardId        Int
  fieldId       Int
  conversationId Int
  accountId     Int
  value         String?     @db.Text // Valor armazenado como texto (JSON para multi_select)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  card          Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field         CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldId])
  @@index([cardId])
  @@index([fieldId])
  @@index([conversationId])
  @@index([accountId])
}

// Tarefas vinculadas a uma conversa
model Task {
  id             Int       @id @default(autoincrement())
  conversationId Int
  accountId      Int
  title          String
  completed      Boolean   @default(false)
  dueDate        DateTime?
  createdBy      Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([conversationId, accountId])
}

// Anexos vinculados a uma conversa
model Attachment {
  id             Int      @id @default(autoincrement())
  conversationId Int
  accountId      Int
  fileName       String   // Nome único gerado
  originalName   String   // Nome original do arquivo
  fileSize       Int
  mimeType       String
  filePath       String
  uploadedBy     Int
  createdAt      DateTime @default(now())

  @@index([conversationId, accountId])
}

// Mensagens agendadas para envio automático
model ScheduledMessage {
  id             Int       @id @default(autoincrement())
  conversationId Int
  accountId      Int
  message        String    @db.Text
  scheduledAt    DateTime
  status         String    @default("pending") // pending, sent, failed, cancelled
  sentAt         DateTime?
  errorMessage   String?
  createdBy      Int
  apiToken       String?   // Token do usuário que criou, para enviar a mensagem
  // Headers JWT para autenticação (quando não há apiToken)
  jwtAccessToken String?
  jwtClient      String?
  jwtUid         String?
  jwtExpiry      String?
  jwtTokenType   String?
  // Anexos (JSON array): [{ fileName, filePath, fileType, fileSize }]
  attachments    String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([conversationId, accountId])
  @@index([status, scheduledAt])
}

// Chat interno entre usuários
model InternalChat {
  id          Int                   @id @default(autoincrement())
  name        String
  accountId   Int
  createdBy   Int                   // ID do admin que criou
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  members     InternalChatMember[]
  messages    InternalChatMessage[]

  @@index([accountId])
}

// Membros de um chat interno
model InternalChatMember {
  id        Int          @id @default(autoincrement())
  chatId    Int
  userId    Int          // ID do usuário no Chatwoot
  joinedAt  DateTime     @default(now())
  chat      InternalChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
}

// Mensagens do chat interno
model InternalChatMessage {
  id          Int          @id @default(autoincrement())
  chatId      Int
  userId      Int          // ID do usuário que enviou
  content     String       @db.Text
  attachments String?      @db.Text // JSON array com anexos
  createdAt   DateTime     @default(now())
  chat        InternalChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([userId])
}


// Permissões de funcionalidades por account (empresa)
model AccountPermissions {
  id                     Int      @id @default(autoincrement())
  accountId              Int      @unique
  kanbanEnabled          Boolean  @default(true)  // Acesso ao Kanban
  chatsInternosEnabled   Boolean  @default(true)  // Acesso aos Chats Internos
  conexoesEnabled        Boolean  @default(true)  // Acesso às Conexões
  projectsEnabled        Boolean  @default(true)  // Acesso aos Projetos
  chatbotFlowsEnabled    Boolean  @default(true)  // Acesso ao Chatbot Flows
  wavoipEnabled          Boolean  @default(false) // Acesso ao Wavoip (ligações WhatsApp)
  allowedProviders       String?  @db.Text // JSON array: ["evolution", "waha"] - Provedores permitidos para conexões
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([accountId])
}

// Permissões de recursos por usuário
// Controla o acesso individual de cada usuário aos recursos da empresa
model UserResourcePermission {
  id                   Int      @id @default(autoincrement())
  accountId            Int      // Empresa
  userId               Int      // Usuário do Chatwoot
  kanbanAccess         Boolean  @default(true)   // Acesso ao Kanban
  conexoesAccess       Boolean  @default(true)   // Acesso às Conexões/Instâncias
  chatsInternosAccess  Boolean  @default(true)   // Acesso aos Chats Internos
  projectsAccess       Boolean  @default(true)   // Acesso aos Projetos
  chatbotFlowsAccess   Boolean  @default(true)   // Acesso aos Chatbot Flows
  wavoipAccess         Boolean  @default(true)   // Acesso ao Wavoip (ligações WhatsApp)
  permissoesAccess     Boolean  @default(false)  // Acesso ao gerenciamento de permissões (apenas admins)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([accountId, userId])
  @@index([accountId])
  @@index([userId])
  @@index([accountId, userId])
}

// Tokens de API para acesso programático
model ApiToken {
  id          Int      @id @default(autoincrement())
  accountId   Int      // Empresa dona do token
  userId      Int      // Usuário que criou o token
  name        String   // Nome descritivo do token (ex: "Integração com Sistema X")
  token       String   @unique // Token gerado (UUID)
  permissions String   @db.Text // JSON: ["kanban:read", "kanban:write", "cards:create", etc]
  lastUsedAt  DateTime? // Última vez que o token foi usado
  expiresAt   DateTime? // Data de expiração (opcional)
  isActive    Boolean  @default(true) // Permite desativar sem deletar
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
  @@index([token])
  @@index([accountId, isActive])
}

// Tipo de flow: chatbot (tempo real) ou sequence (assíncrono)
enum FlowType {
  chatbot
  sequence
}

// Flows de chatbot e sequências para automações
model ChatbotFlow {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?        @db.Text
  accountId     Int
  type          FlowType       @default(chatbot) // NOVO: chatbot ou sequence
  isActive      Boolean        @default(false)
  trigger       String         @db.Text // JSON: { type, value }
  flowData      String         @db.Text // JSON: { nodes: [], edges: [] }
  agentBotId    Int?           // ID do Agent Bot criado no Chatwoot para este flow
  createdBy     Int
  creatorAccessToken String?   @db.Text // Access token do criador (para envio de mensagens)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  executions    FlowExecution[]
  sequenceExecutions SequenceExecution[] // NOVO: Para type = sequence

  @@index([accountId])
  @@index([accountId, isActive])
  @@index([accountId, type])
  @@index([agentBotId])
}

// Execuções de flows de chatbot
model FlowExecution {
  id             Int          @id @default(autoincrement())
  flowId         Int
  conversationId Int
  accountId      Int
  status         String       @default("queued") // queued, running, completed, failed, cancelled
  currentNodeId  String?
  context        String?      @db.Text // JSON com variáveis
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  errorMessage   String?      @db.Text

  flow           ChatbotFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([conversationId])
  @@index([accountId])
  @@index([status])
}

// Variáveis customizadas para flows
model FlowVariable {
  id             Int      @id @default(autoincrement())
  accountId      Int
  name           String
  defaultValue   String?  @db.Text
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountId, name])
  @@index([accountId])
}

// Credenciais de IA para integração com provedores (OpenAI, Groq, etc)
model AICredentials {
  id            Int      @id @default(autoincrement())
  accountId     Int
  provider      String   // "openai" ou "groq"
  apiKey        String   @db.Text // Criptografado
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([accountId, provider])
  @@index([accountId])
}

// Configurações de sistema e integrações externas por conta
model SystemSettings {
  id                      Int      @id @default(autoincrement())
  accountId               Int      @unique

  // Chatwoot Database e Platform Token
  chatwootDatabaseUrl     String?  @db.Text // Criptografado
  chatwootPlatformToken   String?  @db.Text // Criptografado
  chatwootGlobalWebhookId String?  // ID do webhook global criado automaticamente

  // Evolution API
  evolutionApiUrl         String?
  evolutionApiKey         String?  @db.Text // Criptografado

  // WAHA
  wahaApiUrl              String?
  wahaApiKey              String?  @db.Text // Criptografado

  // UaZapi
  uazapiBaseUrl           String?
  uazapiAdminToken        String?  @db.Text // Criptografado

  // Chave de encriptação customizada (opcional)
  customEncryptionKey     String?  @db.Text // Criptografado

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([accountId])
}

// Base de Conhecimento para AI Agents
model KnowledgeBase {
  id          Int                 @id @default(autoincrement())
  accountId   Int
  name        String
  description String?
  createdBy   Int
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  documents   KnowledgeDocument[]

  @@index([accountId])
}

// Documentos (PDFs) da Base de Conhecimento
model KnowledgeDocument {
  id              Int           @id @default(autoincrement())
  knowledgeBaseId Int
  fileName        String        // Nome único gerado
  originalName    String        // Nome original do arquivo
  fileSize        Int
  mimeType        String
  filePath        String        // Caminho do arquivo no servidor
  content         String        @db.Text // Texto extraído do PDF
  uploadedBy      Int
  uploadedAt      DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
}

// Templates de Itens (produtos/serviços) reutilizáveis por funil
model ItemTemplate {
  id          Int      @id @default(autoincrement())
  funnelId    Int
  accountId   Int
  title       String
  description String?  @db.Text
  value       Int      @default(0)  // Valor em centavos (ex: 19990 = R$ 199,90)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  funnel      Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  cardItems   CardItem[]

  @@index([funnelId])
  @@index([accountId])
}

// Itens (produtos/serviços) vinculados a cards
model CardItem {
  id              Int      @id @default(autoincrement())
  cardId          Int
  conversationId  Int
  accountId       Int
  templateId      Int?     // Null se criado manualmente
  title           String
  description     String?  @db.Text
  value           Int      @default(0)  // Centavos
  quantity        Int      @default(1)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  card            Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  template        ItemTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([conversationId])
  @@index([accountId])
}

// ============================================================================
// PROJETOS - Agrupador de conversas relacionadas
// ============================================================================

model Project {
  id              Int       @id @default(autoincrement())
  accountId       Int
  name            String
  description     String?   @db.Text
  status          String    @default("active") // active, completed, cancelled
  deadline        DateTime?
  color           String?   // Cor em hex para identificação visual (ex: #3B82F6)
  createdBy       Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conversations   ProjectConversation[]
  tasks           ProjectTask[]
  milestones      ProjectMilestone[]
  members         ProjectMember[]
  files           ProjectFile[]
  discussions     ProjectDiscussion[]
  activities      ProjectActivity[]

  @@index([accountId])
  @@index([status])
  @@index([createdBy])
}

// Relação Many-to-Many entre Projetos e Conversas
model ProjectConversation {
  id             Int      @id @default(autoincrement())
  projectId      Int
  conversationId Int
  cardId         Int?     // Referência ao card para facilitar queries (opcional)
  addedAt        DateTime @default(now())
  addedBy        Int

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, conversationId])
  @@index([conversationId])
  @@index([cardId])
  @@index([projectId])
}

// ============================================================================
// GERENCIAMENTO DE PROJETOS - Tarefas, Milestones, Membros, etc.
// ============================================================================

// Tarefas do projeto (não vinculadas a conversas)
model ProjectTask {
  id          Int       @id @default(autoincrement())
  projectId   Int
  title       String
  description String?   @db.Text
  status      String    @default("pending") // pending, in_progress, completed
  priority    String?   // low, medium, high, urgent
  dueDate     DateTime?
  completedAt DateTime?
  milestoneId Int?
  assignedTo  Int?      // userId (Chatwoot user)
  createdBy   Int
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone   ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([milestoneId])
  @@index([assignedTo])
  @@index([status])
}

// Milestones/Marcos do projeto
model ProjectMilestone {
  id          Int       @id @default(autoincrement())
  projectId   Int
  name        String
  description String?   @db.Text
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       ProjectTask[]

  @@index([projectId])
}

// Membros da equipe do projeto
model ProjectMember {
  id          Int       @id @default(autoincrement())
  projectId   Int
  userId      Int       // Chatwoot user ID
  role        String    @default("member") // manager, member
  addedAt     DateTime  @default(now())
  addedBy     Int

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// Arquivos do projeto
model ProjectFile {
  id              Int       @id @default(autoincrement())
  projectId       Int
  filename        String
  originalName    String
  mimetype        String
  size            Int       // bytes
  uploadedBy      Int
  uploadedAt      DateTime  @default(now())

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Discussões do projeto
model ProjectDiscussion {
  id          Int       @id @default(autoincrement())
  projectId   Int
  subject     String
  description String?   @db.Text
  createdBy   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments    ProjectComment[]

  @@index([projectId])
}

// Comentários nas discussões
model ProjectComment {
  id            Int       @id @default(autoincrement())
  discussionId  Int
  content       String    @db.Text
  createdBy     Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  discussion    ProjectDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

// Log de atividades do projeto
model ProjectActivity {
  id          Int       @id @default(autoincrement())
  projectId   Int
  userId      Int       // quem fez a ação
  action      String    // "created", "updated", "task_added", "file_uploaded", etc.
  description String    @db.Text // Descrição em português
  metadata    Json?     // Dados adicionais (ex: nome da tarefa, arquivo, etc.)
  createdAt   DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

// ============================================================================
// UAZAPI - Configurações e Instâncias
// ============================================================================

// Configurações do provedor Uazapi por conta
model UazapiConfig {
  id          Int      @id @default(autoincrement())
  accountId   Int      @unique
  baseUrl     String
  adminToken  String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
}

// Tokens de instâncias Uazapi criadas
model UazapiInstance {
  id            Int      @id @default(autoincrement())
  accountId     Int
  instanceName  String
  instanceToken String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([accountId, instanceName])
  @@index([accountId])
}

// ============================================================================
// SEQUÊNCIAS ASSÍNCRONAS - Automações ao longo do tempo
// ============================================================================

enum SequenceStatus {
  pending     // Aguardando início
  running     // Executando
  waiting     // Aguardando delay
  paused      // Pausada manualmente
  completed   // Concluída
  canceled    // Cancelada
  failed      // Falhou
}

enum StepStatus {
  pending     // Aguardando execução
  scheduled   // Agendado para execução futura (delays)
  executing   // Executando agora
  completed   // Concluído
  failed      // Falhou
  skipped     // Pulado (condições não atendidas)
}

// Execução de uma sequência para um contato específico
model SequenceExecution {
  id              Int               @id @default(autoincrement())
  flowId          Int
  accountId       Int
  contactId       Int               // ID do contato no Chatwoot
  conversationId  Int?              // Conversa associada (opcional)
  status          SequenceStatus    @default(pending)
  currentNodeId   String?           // Node atual sendo executado
  context         String?           @db.Text // JSON com variáveis e estado
  startedAt       DateTime          @default(now())
  pausedAt        DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  errorMessage    String?           @db.Text
  // Credenciais para enviar mensagens (do usuário que iniciou a sequência)
  apiToken        String?           // API token do usuário
  jwtAccessToken  String?           // JWT access-token
  jwtClient       String?           // JWT client
  jwtUid          String?           // JWT uid
  jwtExpiry       String?           // JWT expiry
  jwtTokenType    String?           // JWT token-type

  flow            ChatbotFlow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  steps           SequenceStep[]

  @@index([accountId, contactId])
  @@index([flowId, status])
  @@index([status])
  @@index([conversationId])
}

// Cada passo executado ou agendado de uma sequência
model SequenceStep {
  id            Int                 @id @default(autoincrement())
  executionId   Int
  nodeId        String              // ID do node no flow
  nodeType      String              // Tipo do node (sendText, delay, etc)
  status        StepStatus          @default(pending)
  scheduledFor  DateTime?           // Quando deve executar (para delays)
  executedAt    DateTime?           // Quando foi executado
  error         String?             @db.Text
  data          String?             @db.Text // JSON com dados do node executado

  execution     SequenceExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([scheduledFor, status])  // Para buscar steps a executar
  @@index([status])
}

model WebhookConfig {
  id        Int      @id @default(autoincrement())
  accountId Int
  name      String
  url       String
  events    String   // JSON array: ["card.created","card.moved","card.deleted"]
  isActive  Boolean  @default(true)
  secret    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([accountId, isActive])
}

// Token Wavoip associado a uma conexão WhatsApp (por instanceName)
model WavoipToken {
  id           Int      @id @default(autoincrement())
  accountId    Int
  instanceName String   // nome da instância/conexão (inbox name no Chatwoot)
  provider     String   // "evolution" | "waha" | "uazapi"
  deviceToken  String   @db.Text // criptografado com AES-256-CBC
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([accountId, instanceName])
  @@index([accountId])
}

// Histórico de chamadas realizadas via Wavoip
model CallHistory {
  id              Int      @id @default(autoincrement())
  accountId       Int
  conversationId  Int?
  contactPhone    String
  contactName     String?
  direction       String   // "INCOMING" | "OUTGOING"
  status          String   // "ENDED" | "REJECTED" | "NOT_ANSWERED" | "FAILED"
  instanceName    String?  // qual conexão foi usada
  durationSeconds Int?
  startedAt       DateTime?
  endedAt         DateTime?
  recordingPath   String?   // caminho relativo: "recordings/rec-xxx.webm"
  recordingSize   Int?      // tamanho em bytes
  createdAt       DateTime @default(now())

  @@index([accountId])
  @@index([accountId, conversationId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  accountId Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId, accountId])
}
